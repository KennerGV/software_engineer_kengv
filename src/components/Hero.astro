---
// Importamos los datos directamente
interface Props {
  cv: {
    sobreMi: string;
  };
}
const { cv } = Astro.props;
const { sobreMi } = cv;
const { currentLocale } = Astro;
const seccionTitulo = currentLocale === 'es' ? 'Sobre Mí' : 'About Me';
---
<section class="experience-section">
  <h2>{seccionTitulo}</h2>
    <div class="job-card">
      <div class="header">
        
        <span>{sobreMi}</span>
      </div>      
    </div>
</section>

<style>
  .experience-section {
    max-width: 800px;
    margin: 2rem auto;
  }
  .job-card {
    margin-bottom: 2rem;
    border-left: 2px solid #007acc;
    padding-left: 1.5rem;
  }
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  h3 { margin: 0; color: #1a1a1a; }
  .company { font-weight: bold; color: #555; }
</style>