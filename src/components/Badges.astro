---
// src/components/BadgeCredly.astro
interface CredlyBadge {
  nombre: string;
  id: string;
}

interface MicrosoftBadge {
  nombre: string;
  imageUrl: string;
  credentialUrl: string;
}

// 2. Especificamos el tipado formal de las Props que recibirá desde el index
interface Props {
  cv: {
    badges?: {
      credly?: CredlyBadge[];
      microsoft?: MicrosoftBadge[];
    };
  };
}
const { cv } = Astro.props;

// Extraemos las colecciones de forma segura usando desestructuración.
// Asignamos un arreglo vacío por defecto '|| []' por si alguna sección no existe aún.
const credlyBadges = cv.badges?.credly || [];
const microsoftBadges = cv.badges?.microsoft || [];
---
<div class="badge-section">
    <h2>Badges</h2>
    <div class="badges-grid">
        {microsoftBadges.map((badge) => (
        <a 
          href={badge.credentialUrl} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="badge-item microsoft-container"
          title={`Ver certificación oficial: ${badge.nombre}`}
        >
          <img 
            src={badge.imageUrl} 
            alt={badge.nombre} 
            class="microsoft-badge-img"
          />
        </a>
      ))}
      {credlyBadges.map((badge) => (
        <div 
          class="badge-item"
          data-iframe-width="150" 
          data-iframe-height="270" 
          data-share-badge-id={badge.id} 
          data-share-badge-host="https://www.credly.com"
          title={badge.nombre}
        ></div>
      ))}
    </div>
</div>

<script is:inline type="text/javascript" src="https://cdn.credly.com/assets/utilities/embed.js"></script>

<style>
  .badges-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;          
    justify-content: flex-start; 
    margin-top: 1rem;
  }

  .badge-item {
    display: inline-block;
    width: 150px;       
    height: 270px;      
    flex-shrink: 0;
  }

  .microsoft-container {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 15px;
    text-decoration: none;
    transition: transform 0.2s ease-in-out;
  }

  .microsoft-container:hover {
    transform: scale(1.05);
  }

  .microsoft-badge-img {
    width: 110px;
    height: auto;
    object-fit: contain;
  }

  .badge-item :global(iframe) {
    border: none !important;        
    outline: none !important;       
    box-shadow: none !important;    
  }
</style>