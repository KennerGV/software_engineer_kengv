---
// Importamos los datos directamente
interface Props {
  cv: {
    experiencia: Array<{
      puesto: string;
      empresa: string;
      periodo: string;
      proyectos: Array<{
        cliente: string;
        periodo: string;
        detalles: string[];
      }>;
    }>;
  };
}
const { cv } = Astro.props;
const { experiencia } = cv;
const { currentLocale } = Astro;
const seccionTitulo = currentLocale === 'es' ? 'Experiencia Profesional' : 'Professional Experience';
---

<section class="experience-section">
  <h2>{seccionTitulo}</h2>
  {experiencia.map((job) => (
    <div class="job-card">
      <div class="header">
        <h3>{job.puesto}</h3>
        <span>{job.periodo}</span>
      </div>
      <p class="company">{job.empresa}</p>
      <ul>
        {job.proyectos.map((proyecto) => (
          <h4 class="cliente">{proyecto.cliente} {proyecto.periodo}</h4>
          <ul>{proyecto.detalles.map(item => <li>{item}</li>)}</ul>
        ))}
      </ul>
    </div>
  ))}
</section>

<style>
  .experience-section {
    max-width: 800px;
    margin: 2rem auto;
  }
  .job-card {
    margin-bottom: 2rem;
    border-left: 2px solid #007acc;
    padding-left: 1.5rem;
  }
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  h3 { margin: 0; color: #1a1a1a; }
  .company { font-weight: bold; color: #555; }
  .cliente { font-weight: bold; color: #555; }
</style>