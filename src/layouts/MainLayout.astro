---
import Sidebar from '../components/SideBar.astro';
import '../styles/global.css';
import FloatingActions from '../components/FloatingActions.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';

const { title = "Kener Gutiérrez | Software Engineer" } = Astro.props;
const { cvData } = Astro.props;
const { currentLocale } = Astro;
---

<!DOCTYPE html>
<html lang={currentLocale}>
<head>
    <head>
    <meta charset="utf-8" />
    <title>CV - {cvData.nombre}</title>
    <style>
      body { font-family: system-ui, sans-serif; line-height: 1.6; color: #333; background: #f9f9f9; }
    </style>
    <GoogleAnalytics />
  </head>
</head>
<body>
    <Sidebar cv={cvData} />
    <header style="text-align: center; padding: 4rem 1rem; background: #fff;">
      <h1>{cvData.nombre}</h1>
      <p>{cvData.puesto} | {cvData.ubicacion}</p>
    </header>
    <main>
        <slot />
        <FloatingActions />
    </main>
  </body>
</html>